# MqDockerUp Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.

# MQTT Configuration
# MQTT_CONNECTIONURI is non-secret config -- set it in your compose environment: block instead.
# MQTT_CONNECTIONURI=mqtt://broker:1883
MQTT_USERNAME=ha
MQTT_PASSWORD=

# Access Tokens
ACCESSTOKENS_GITHUB=
ACCESSTOKENS_DOCKERHUB=

# Application API Keys (optional) - for fetching release notes from app APIs
# Get API keys from each application: Settings > General > Security > API Key
APPLICATIONAPIS_RADARR_APIKEY=
APPLICATIONAPIS_SONARR_APIKEY=
APPLICATIONAPIS_LIDARR_APIKEY=
APPLICATIONAPIS_READARR_APIKEY=
APPLICATIONAPIS_PROWLARR_APIKEY=
APPLICATIONAPIS_BAZARR_APIKEY=

# Optional: Override auto-detected base URLs
# APPLICATIONAPIS_RADARR_BASEURL=http://radarr:7878
# APPLICATIONAPIS_SONARR_BASEURL=http://sonarr:8989
# APPLICATIONAPIS_LIDARR_BASEURL=http://lidarr:8686
# APPLICATIONAPIS_READARR_BASEURL=http://readarr:8787
# APPLICATIONAPIS_PROWLARR_BASEURL=http://prowlarr:9696
# APPLICATIONAPIS_BAZARR_BASEURL=http://bazarr:6767
